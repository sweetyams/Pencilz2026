{
  "enabled": true,
  "name": "Tasks: sync to prod",
  "description": "Automatically syncs completed task status to production after pushing code live, keeping production tasks in sync with local fixes",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "npm run sync:task-status"
  },
  "workspaceFolderName": "Pencilz2026",
  "shortName": "sync-task-status-prod"
}