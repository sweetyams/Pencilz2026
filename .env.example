# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS in production)
FRONTEND_URL=https://your-app.ondigitalocean.app

# API URL for frontend (optional - defaults to localhost:3001 in dev, same-origin in prod)
VITE_API_URL=http://localhost:3001

# Vercel Blob Storage (required for production image uploads)
# Get this from: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=your_blob_token_here
